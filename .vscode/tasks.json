{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build My Game",
            "type": "shell",
            "command": "g++",
            "args": [
                "-fcolor-diagnostics",
                "-fansi-escape-codes",
                "-g",
                "${workspaceFolder}/main.cpp",
                "${workspaceFolder}/src/inventory.cpp",
                "${workspaceFolder}/src/player.cpp",
                "-o",
                "${workspaceFolder}/game",
                "-I", "/opt/homebrew/include",
                "-L", "/opt/homebrew/lib",
                "-lraylib",
                "-std=c++17",
                "-framework", "CoreVideo",
                "-framework", "IOKit",
                "-framework", "Cocoa",
                "-framework", "GLUT",
                "-framework", "OpenGL"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}